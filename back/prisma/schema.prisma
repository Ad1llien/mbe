generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  isVerified        Boolean  @default(false)
  verificationToken String?
  referralCode      String   @unique @default(dbgenerated("gen_random_uuid()"))
  referredBy        String?
  bonusBalance      Float    @default(0)
  createdAt         DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String   @unique
  price     Float
  unit      String   @default("pcs")
  createdAt DateTime @default(now())
}

model Receipt {
  id        String        @id @default(uuid())
  number    String        @unique
  total     Float
  cashierId String
  createdAt DateTime      @default(now())
  voided    Boolean       @default(false)
  items     ReceiptItem[]
  voidReason String?

}

model ReceiptItem {
  id        String  @id @default(uuid())
  receiptId String
  productId String
  name      String
  price     Float
  qty       Int
  receipt   Receipt @relation(fields: [receiptId], references: [id])
}

model Business {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  webhookSecret String? @default(uuid())
  createdAt DateTime @default(now())
  leads     Lead[]
}

model Lead {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String?
  phone      String?
  email      String?
  source     String?
  status     String   @default("new")
  createdAt  DateTime @default(now())
}

model Task {
  id        String   @id @default(uuid())
  userId    String
  title     String
  due       DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model StaffMember {
  id          String          @id @default(uuid())
  ownerId     String
  name        String
  email       String          @unique
  password    String
  role        String          @default("cashier")
  phone       String
  pin         String
  kpiTarget   Int             @default(0)
  status      String          @default("active")
  verified    Boolean         @default(false)
  verifyToken String?         @unique
  permissions Json            @default("[]")
  hiredAt     DateTime        @default(now())
  createdAt   DateTime        @default(now())
  activities  StaffActivity[]
  shifts      StaffShift[]
}

model StaffShift {
  id        String      @id @default(uuid())
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  clockIn   DateTime
  clockOut  DateTime?
  note      String?
  editedBy  String?
  createdAt DateTime    @default(now())
}

model StaffActivity {
  id        String      @id @default(uuid())
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type      String      // login, shift_start, shift_end, sale
  note      String?
  amount    Float?
  createdAt DateTime    @default(now())
}

model Appointment {
  id        String   @id @default(uuid())
  userId    String
  title     String
  start     DateTime
  duration  Int
  color     String   @default("stage-progress")
  note      String?
  clients   Json     @default("[]")
  contacts  Json     @default("[]")
  dealId    String?
  createdAt DateTime @default(now())
}